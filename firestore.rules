rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — owner only read/write
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Tickets — owner read/create only
    // No client update or delete — Admin SDK only
    match /tickets/{ticketId} {
      allow read, create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Elections — public read, no client writes
    match /elections/{electionId} {
      allow read: if true;
      allow write: if false;

      // Election results subcollection
      match /results/{resultId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Police stations — public read, no client writes
    match /policeStations/{stationId} {
      allow read: if true;
      allow write: if false;
    }

    // Polling booths — public read, no client writes
    match /pollingBooths/{boothId} {
      allow read: if true;
      allow write: if false;
    }

    // Gemini cache — no client access at all
    match /geminiCache/{cacheId} {
      allow read, write: if false;
    }

    // Rate limits — no client access at all
    match /rateLimits/{limitId} {
      allow read, write: if false;
    }

    // Catch-all — deny everything not explicitly permitted
    match /{document=**} {
      allow read, write: if false;
    }
  }
}